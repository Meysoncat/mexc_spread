@@ -1029,6 +1118,11 @@ def snapshot(
         else:
             m = None
         cache_key = f"{ex}:{m or 'default'}"
+        _mark_snapshot_hot(
+            cache_key,
+            lambda: _build_exchange_snapshot_payload(ex, m),
+            _snapshot_ttl_for(ex),
