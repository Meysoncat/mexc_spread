+def _parse_bitget(msg: Any) -> list[_Update] | None:
+    if not isinstance(msg, dict):
+        return None
+    arg = msg.get("arg")
+    data = msg.get("data")
+    if not isinstance(arg, dict) or not isinstance(data, list):
+        return None
+    if arg.get("channel") != "ticker":
